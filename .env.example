# Bonaparte — environment variables
# Copy to %APPDATA%\Bonaparte\.env on Windows (the app seeds this on first run)
# or set BONAPARTE_USER_DIR to a custom directory.

# Slack
SLACK_USER_TOKEN=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# HubSpot
HUBSPOT_TOKEN=

# Anthropic (optional; falls back to ~/.claude/.credentials.json if Claude Code is signed in)
ANTHROPIC_API_KEY=

# Other
VITUS_API_KEY=
TAVILY_API_KEY=

# Server
PORT=3000
